<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#d2ebfc"
    android:orientation="vertical"
    tools:context=".activity.login.RegisterActivity">


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="20dp"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="30dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="账号注册"
            android:textColor="#202020"
            android:textSize="30dp" />


        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="欢迎使用慧行助手!" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#FFFFFF"
        app:cardCornerRadius="15dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="30dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvAccNum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="账号"
                android:textColor="#202020"
                />

            <EditText
                android:id="@+id/etAccNum"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入手机号!"
                android:layout_marginTop="10dp"
                android:padding="10dp"
                android:maxLength="11"
                android:inputType="phone"
                android:maxLines="1"
                android:imeOptions="actionNext"
                android:background="@drawable/rounded_edit"
                />

            <TextView
                android:id="@+id/tvPwd"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="密码"
                android:layout_marginTop="20dp"
                android:textColor="#202020"
                />

            <EditText
                android:id="@+id/etPwd"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="请输入密码!"
                android:layout_marginTop="10dp"
                android:padding="10dp"
                android:imeOptions="actionNext"
                android:maxLines="1"
                android:inputType="textPassword"
                android:background="@drawable/rounded_edit"
                />

            <TextView
                android:id="@+id/tvCode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="验证码"
                android:textColor="#202020"
                />

            <LinearLayout
                android:id="@+id/llCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="10dp"
                >
                <EditText
                    android:id="@+id/etCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/rounded_edit"
                    android:hint="请输入验证码!"
                    android:maxLines="1"
                    android:inputType="number"
                    android:imeOptions="actionDone"
                    android:padding="10dp" />

                <Button
                    android:id="@+id/btCode"
                    android:layout_width="90dp"
                    android:layout_height="35dp"
                    android:layout_marginLeft="-95dp"
                    android:text="获取验证码"
                    android:layout_gravity="center"
                    android:textColor="#FFFFFF"
                    android:background="@drawable/rounded_but"

                    />
            </LinearLayout>

            <TextView
                android:id="@+id/tvShowCode"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:textColor="#0066CC"
                android:visibility="gone" /> <!-- 初始隐藏，获取验证码后显示 -->
        </LinearLayout>

        <Button
            android:id="@+id/btLogin"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="40dp"
            android:background="@drawable/rounded_but2"
            android:text="登录账号"
            android:textSize="20dp" />

        <Button
            android:id="@+id/btRegister"
            android:layout_width="200dp"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="120dp"
            android:background="@drawable/rounded_but"
            android:textColor="#FFFFFF"
            android:text="注册账号"
            android:textSize="20dp" />
    </androidx.cardview.widget.CardView>
</LinearLayout>